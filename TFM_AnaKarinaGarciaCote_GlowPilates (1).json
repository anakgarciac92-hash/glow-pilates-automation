    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  const socio = item.json;\n  const nombrePila = socio.Nombre.split(' ')[0];\n  let mensaje = \"\";\n\n  if (socio.Plan === 'Ilimitado' && socio['Clases usadas'] == 0) {\n    mensaje = `<p>¡Hola ${nombrePila}! 👋</p>\n               <p>Tienes activo tu <b>Plan Ilimitado</b> en Glow Pilates, pero hemos visto que este mes aún no has podido venir a entrenar.</p>\n               <p>Tu periodo de facturación renueva en ${socio.diasRestantes} días. ¡Aprovecha estos días para volver a las máquinas y sacarle partido a tu tarifa!</p>`;\n  } \n\n  else {\n    mensaje = `<p>Hola ${nombrePila}, ¿cómo va todo? 😊</p>\n               <p>Te escribo porque tus clases de este mes <b>caducan en solo ${socio.diasRestantes} días</b> y aún tienes <b>${socio.pendientes} clases</b> disponibles.</p>\n               <p>Como sabes, las clases no se acumulan para el mes siguiente, así que te animamos a que reserves tus sesiones antes de la fecha de renovación para no perderlas.</p>`;\n  }\n\n  item.json.cuerpoEmail = mensaje + \"<p>¡Te esperamos pronto!<br><b>Glow Pilates 💙</b></p>\";\n}\n\nreturn $input.all();"
      },
