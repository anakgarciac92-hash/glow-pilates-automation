{
  "name": "TFM_AnaKarinaGarciaCote_GlowPilates",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const hoy = new Date();\nconst resultado = [];\n\nfor (const item of $input.all()) {\n  const socio = item.json;\n  \n  if (socio['Correo enviado'] === 'Sí' || socio['Estado'] === 'Usado') continue;\n  if (!socio['Ultima Clase'] || !socio['Fecha de renovación']) continue;\n\n  const renovacion = new Date(socio['Fecha de renovación'].split('/').reverse().join('-'));\n  const ultimaClase = new Date(socio['Ultima Clase'].split('/').reverse().join('-'));\n  \n  const diasRestantes = Math.floor((renovacion - hoy) / (1000 * 60 * 60 * 24));\n  const diasSinVenir = Math.floor((hoy - ultimaClase) / (1000 * 60 * 60 * 24));\n  const usadas = Number(socio['Clases usadas']) || 0;\n  \n  let planTotal = (socio.Plan === 'Ilimitado') ? 20 : Number(socio.Plan) || 0;\n  const pendientes = planTotal - usadas;\n  \n  let dispararAlerta = false;\n\n  if (socio.Plan === 'Ilimitado') {\n      if (diasRestantes <= 3 && usadas >= 8) {\n          dispararAlerta = false; \n      }\n      else if (diasSinVenir >= 10 || (diasRestantes <= 15 && usadas < 4)) {\n          dispararAlerta = true;\n      }\n  } \n  else if (socio.Plan == 8 && diasRestantes <= 10 && pendientes >= 4) {\n      dispararAlerta = true;\n  }\n  else if (socio.Plan == 4 && diasRestantes <= 7 && pendientes >= 2) {\n      dispararAlerta = true;\n  }\n\n  if (dispararAlerta) {\n    const bonoUrgente = (diasRestantes <= 3); \n    \n    resultado.push({ \n      json: { \n        ...socio, \n        bonoUrgente, \n        diasRestantes, \n        pendientes, \n        diasSinVenir \n      } \n    });\n  }\n}\n\nreturn resultado;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -32,
        0
      ],
