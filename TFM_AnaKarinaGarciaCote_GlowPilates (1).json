        "jsCode": "const alumnosSinRespuesta = $input.all();\nlet mensaje = \"📋 *LLAMADAS PENDIENTES (24h sin respuesta)*\\n\\n\";\n\nif (alumnosSinRespuesta.length === 0) {\n  return [{ json: { mensajeFinal: \"Hoy no hay llamadas pendientes.\" } }];\n}\n\nfor (const item of alumnosSinRespuesta) {\n  const correo = item.json[\"Correo electrónico\"] || \"Sin correo\";\n  const nombre = item.json[\"Nombre\"] || correo;\n  const telefono = item.json[\"Teléfono\"] || \"Sin teléfono\";\n  mensaje += `👤 *${nombre}*\\n📞 ${telefono}\\n-----------\\n`;\n}\n\nreturn [{ json: { mensajeFinal: mensaje } }];"
